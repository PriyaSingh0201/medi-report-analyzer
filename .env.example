# Flask configuration settings
SECRET_KEY=dev_secret_key_change_in_production_123!
PORT=5000
DEBUG=False

# Optional Tesseract OCR executable path (set only if Tesseract is installed)
# Example Windows:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Example macOS/Linux:
# TESSERACT_CMD=/usr/local/bin/tesseract
TESSERACT_CMD=

# Optional SMTP configuration for critical email alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SENDER_EMAIL=alerts@dooper-reports.com
